# Скопируйте в .env в корне проекта (файл .env в git не попадает)
# Переменные перекрывают config/settings.yaml — см. docs/api/ENV.md

# --- CRM / каталог (тот же backend, что mini app Катюша: 699.ru / katushamarket.ru) ---
# Базовый URL из docs/CRM_API_SPEC.md — уточните путь у разработчиков CRM (/api/v1 и т.д.)
CRM_API_BASE_URL=https://katushamarket.ru/api/v1
CRM_API_KEY=
CRM_KIOSK_ID=kiosk-farm-01
# true = демо-каталог без API; false = HTTP (если задан CRM_API_KEY, mock выключается сам)
CRM_USE_MOCK=true
# split = /categories + /products | combined = /kiosk/catalog
CRM_CATALOG_MODE=split

# --- aQsi (режим tbank_aqsi) ---
AQSI_API_KEY=
AQSI_API_BASE=https://api.aqsi.ru

# --- Т-Банк СБП ---
TBANK_TERMINAL_KEY=
TBANK_TERMINAL_PASSWORD=

# --- Облачная касса (режим tbank_pos_printer) ---
FISCAL_CLOUD_PUBLIC_ID=
FISCAL_CLOUD_API_SECRET=
