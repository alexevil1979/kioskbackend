# Скопируйте в .env в корне проекта (файл .env в git не попадает)
# Переменные перекрывают config/settings.yaml — см. docs/api/ENV.md

# --- Kiosk API Катюша (официально: admin.../docs/kiosk-api) ---
# Заголовок: X-Kiosk-Key (не Bearer). См. docs/api/katusha/KIOSK_API_OFFICIAL.md
KIOSK_API_BASE_URL=https://admin.katushamarket.ru/api/external/kiosk
KIOSK_API_KEY=
# Обратная совместимость (если KIOSK_API_KEY пуст — берётся CRM_API_KEY)
CRM_API_BASE_URL=
CRM_API_KEY=
CRM_KIOSK_ID=
# true = демо-каталог без API; false = HTTP при наличии ключа
CRM_USE_MOCK=true
# Устарело для официального API (каталог только GET /catalog)
CRM_CATALOG_MODE=split
# Тестовый режим покупок: игнорировать доступность из API
PURCHASE_TEST_MODE=false
# Остаток для каждого товара в тест-режиме
PURCHASE_TEST_QTY=5
# false = СБП через POST /order/create (Katusha API)
PAYMENT_SBP_USE_MOCK=false
# Сырой лог API при оплате QR (файл в logs/)
PAYMENT_QR_API_TRACE_ENABLED=true
PAYMENT_QR_API_TRACE_FILE=logs/payment_qr_api.log
# tbank_pos_sbp — выбор СБП/карта + QR на экране; tbank_aqsi — оплата на терминале aQsi
INTEGRATION_MODE=tbank_pos_sbp

# Ошибка оплаты: телефон поддержки (показ включён по умолчанию в settings.yaml)
KIOSK_SUPPORT_PHONE=+7 (900) 000-00-00
KIOSK_SHOW_SUPPORT_PHONE_ON_PAYMENT_ERROR=true

# --- aQsi (режим tbank_aqsi) ---
AQSI_API_KEY=
AQSI_API_BASE=https://api.aqsi.ru

# --- Т-Банк СБП ---
TBANK_TERMINAL_KEY=
TBANK_TERMINAL_PASSWORD=

# --- Облачная касса (режим tbank_pos_printer) ---
FISCAL_CLOUD_PUBLIC_ID=
FISCAL_CLOUD_API_SECRET=
