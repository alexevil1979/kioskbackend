app:
  title: "Сады Коломны — киоск"
  ui_theme: kolomna   # kolomna | katusha
  locale: ru_RU
  fullscreen: true
  orientation: portrait   # portrait | landscape
  screen_width: 1080
  screen_height: 1920
  # Тест на ПК: рабочая область 499×913 как референс + кнопка «Закрыть» (или DEV_MODE=true в .env)
  dev_mode: false
  viewport_width: 499
  viewport_height: 913

idle:
  warning_seconds: 50
  reset_seconds: 60

success:
  auto_return_min_sec: 5
  auto_return_max_sec: 8

catalog:
  poll_interval_sec: 30
  media_dir: media/products
  purchase_test_mode: false  # true: все товары доступны для покупки
  test_stock_qty: 5          # остаток каждого товара в test-режиме

crm:
  # Секреты и URL — в .env: CRM_API_BASE_URL, CRM_API_KEY (см. .env.example)
  base_url: "https://katushamarket.ru/api/v1"
  api_key: ""
  kiosk_id: "kiosk-farm-01"
  timeout_sec: 10
  use_mock: true
  catalog_mode: split   # split | combined
  order_poll_interval_sec: 2   # опрос GET /order/{id}/status при СБП

payment:
  sbp_timeout_sec: 120
  card_terminal_path: ""  # устарело: используйте hardware.tbank_terminal
  # Сырой лог POST/GET /order/* при оплате СБП (QR)
  qr_api_trace_enabled: true
  qr_api_trace_file: logs/payment_qr_api.log
  sbp:
    terminal_key: ""
    password: ""
    api_url: "https://securepay.tinkoff.ru/v2"
    use_mock: true

fiscal:
  enabled: false
  provider: none          # cloudkassir | tbusiness | umka | none
  use_mock: true
  # УМКА — только integration_mode: legacy_umka
  host: "192.168.1.100"
  port: 58088
  use_https: false
  cashier_login: "1"
  cashier_password: "1"
  use_test_server: false
  test_host: "office.armax.ru"
  test_port: 58088
  # Облако — для tbank_pos_printer (ключи в .env)
  cloud_public_id: ""
  cloud_api_secret: ""

hardware:
  # tbank_aqsi — aQsi 6: оплата + фискальный чек на одном устройстве
  # tbank_pos_printer — POS Т-Банк + HS-K33 + облачная касса (БЕЗ УМКА)
  # tbank_pos_sbp — как pos_printer + СБП на экране киоска
  # legacy_umka — УМКА + принтер (старое железо)
  integration_mode: tbank_pos_sbp
  network:
    lan_subnet: "192.168.1.0/24"
    gateway: "192.168.1.1"
  nuc:
    # IP Ethernet NUC в подсети принтера (switch NUC↔HS-K33). Обязателен, если Wi‑Fi и принтер в разных сегментах.
    lan_ip: "192.168.1.10"
  umka:
    host: "192.168.1.100"
    port: 58088
  printer:
    enabled: true
    connection: usb
    # Точное имя в «Устройства и принтеры»; пусто — принтер по умолчанию
    windows_name: "Generic / Text Only"
    windows_datatype: RAW
    windows_encoding: cp866
    windows_codepage_id: -1
    windows_use_direct_port: true
    windows_port: ""
    windows_escpos_codepage: false
    host: "192.168.1.81"
    port: 9100
  tbank_terminal:
    host: "192.168.1.102"
    port: 27015
    smart_sale_enabled: false
    use_mock: true
  aqsi:
    api_base: "https://api.aqsi.ru"
    api_key: ""
    use_mock: true
    timeout_sec: 30
    poll_interval_sec: 2
    poll_max_sec: 180

logging:
  level: INFO
  file: logs/kiosk.log
  max_bytes: 5242880
  backup_count: 3

kiosk:
  block_keys: true
  admin_pin: "1111"
  # Телефон на экране ошибки оплаты (можно переопределить KIOSK_SUPPORT_PHONE в .env)
  support_phone: "+7 (900) 000-00-00"
  # Показывать номер под текстом «Свяжитесь с нами…» (по умолчанию включено)
  show_support_phone_on_payment_error: true
