/* ============================================================
   АДМИНКА — PIN-вход + настройки терминала
   ============================================================ */
function AdminPinModal({ S, onClose, onSuccess, pin }) {
  const [val, setVal] = React.useState("");
  const [err, setErr] = React.useState(false);
  const A = S.admin;
  function push(d) {
    if (val.length >= 4) return;
    const next = val + d;
    setVal(next);
    if (next.length === 4) {
      setTimeout(() => {
        if (next === pin) onSuccess();
        else { setErr(true); setTimeout(() => { setVal(""); setErr(false); }, 650); }
      }, 160);
    }
  }
  function back() { setErr(false); setVal((v) => v.slice(0, -1)); }
  const keys = ["1", "2", "3", "4", "5", "6", "7", "8", "9", "", "0", "⌫"];
  return (
    <div className="admin-overlay" onClick={onClose}>
      <div className="admin-pin" onClick={(e) => e.stopPropagation()}>
        <span className="eyebrow">{A.access}</span>
        <h2 className="t-h2">{A.pinPrompt}</h2>
        <div className={"pin-dots" + (err ? " is-err" : "")}>
          {[0, 1, 2, 3].map((i) => (
            <span key={i} className={"pin-dot" + (i < val.length ? " is-on" : "")}></span>
          ))}
        </div>
        <div className="pin-msg">{err ? A.wrong : "\u00A0"}</div>
        <div className="pin-pad">
          {keys.map((k, i) => k === ""
            ? <span key={i} className="pin-key pin-key--empty" aria-hidden="true"></span>
            : <button key={i} className={"pin-key" + (k === "⌫" ? " pin-key--back" : "")}
                onClick={() => k === "⌫" ? back() : push(k)}>{k}</button>
          )}
        </div>
        <button className="btn btn--ghost btn--lg" onClick={onClose}>{A.cancel}</button>
      </div>
    </div>
  );
}

